      <MdxScripts>
        <MdxScript>
          <ID>MdxScript</ID>
          <Name>MdxScript</Name>
          <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
          <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
          <Commands>
            <Command>
              <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;   
CREATE MEMBER CURRENTCUBE.[Measures].[Avg_Salary]
 AS [Measures].[Monthly Salary] / [Measures].[Fact HR Payroll Count], 
VISIBLE = 1; 
CREATE MEMBER CURRENTCUBE.[Measures].Turnover_Rate
 AS IIF(
    [Measures].[Fact HR Payroll Count] = 0 OR IsEmpty([Measures].[Fact HR Payroll Count]), 
    0, 
    [Measures].[Turnover_Count] / [Measures].[Fact HR Payroll Count]
), 
FORMAT_STRING = "Percent", 
VISIBLE = 1  ; </Text>
            </Command>
          </Commands>
        </MdxScript>
      </MdxScripts>
    </Cube>
