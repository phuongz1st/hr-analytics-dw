  <MdxScripts>
    <MdxScript dwd:design-time-name="1ba8528a-7cfd-4fb1-9de9-7b8ec8543130">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg_Performance]
 AS [Measures].[Performance Score] / [Measures].[Fact Performance Count], 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Avg_Overtime]
 AS [Measures].[Overtime Hours] / [Measures].[Fact Performance Count], 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>