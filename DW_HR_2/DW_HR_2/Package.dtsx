                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
       d.Employee_ID, d.Job_Title, p.Remote_Work_Frequency, p.Team_Size,
       YEAR(DATEADD(year, d.Years_At_Company, CAST(d.Hire_Date AS DATE))) * 10000 + MONTH(DATEADD(year, d.Years_At_Company, CAST(d.Hire_Date AS DATE))) * 100 + DAY(DATEADD(year, d.Years_At_Company, CAST(d.Hire_Date AS DATE))) AS Current_Date_SK,
       p.Performance_Score, p.Work_Hours_Per_Week, p.Projects_Handled, p.Overtime_Hours, p.Training_Hours
   FROM STG_Demographics d
   JOIN STG_Performance p ON d.Employee_ID = p.Employee_ID
   WHERE d.Employee_ID IS NOT NULL AND d.Hire_Date IS NOT NULL</property>
