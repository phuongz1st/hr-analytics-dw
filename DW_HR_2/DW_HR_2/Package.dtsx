                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT 
 YEAR(DATEADD(year, Years_At_Company, CAST(Hire_Date AS DATE))) * 10000 + MONTH(DATEADD(year, Years_At_Company, CAST(Hire_Date AS DATE))) * 100 + DAY(DATEADD(year, Years_At_Company, CAST(Hire_Date AS DATE))) AS Date_SK,
 CAST(DATEADD(year, Years_At_Company, CAST(Hire_Date AS DATE)) AS DATE) AS Date_NK,
 YEAR(DATEADD(year, Years_At_Company, CAST(Hire_Date AS DATE))) AS [Year],
 DATEPART(QUARTER, DATEADD(year, Years_At_Company, CAST(Hire_Date AS DATE))) AS [Quarter],
 MONTH(DATEADD(year, Years_At_Company, CAST(Hire_Date AS DATE))) AS [Month],
 CASE WHEN DATEPART(dw, DATEADD(year, Years_At_Company, CAST(Hire_Date AS DATE))) IN (1, 7) THEN 1 ELSE 0 END AS IsWeekend, 
 0 AS IsHoliday
FROM STG_Demographics
WHERE Hire_Date IS NOT NULL AND Years_At_Company IS NOT NULL</property>
